# 이 파일을 backend/.env로 복사한 뒤 실제 값을 채워 넣으세요.
# .env는 .gitignore에 이미 포함되어 있어 커밋되지 않습니다.
# cp .env.example .env

# AI Health Coach가 실제 OpenAI API를 쓰도록 하려면 설정하세요.
# 비워두면(또는 이 파일을 복사하지 않으면) 지금처럼 규칙 기반 코칭만 사용됩니다.
OPENAI_API_KEY=

# OPENAI_API_KEY를 설정했을 때 사용할 모델 (기본값: gpt-4o-mini)
# OPENAI_COACHING_MODEL=gpt-4o-mini

# 프론트엔드를 다른 origin에서 서빙하게 되면 콤마로 구분해 추가하세요.
# 지금은 index.html/admin.html이 백엔드와 같은 origin(/app)에서 서빙되므로 비워둡니다.
# ALLOWED_ORIGINS=

# HTTPS로 배포할 때 true로 설정하세요 (세션 쿠키에 Secure 속성 적용).
# COOKIE_SECURE=false

# ---------- Web Push (리마인더 알림) ----------
# 아래 두 값이 비어있으면 Web Push 기능 자체가 비활성화됩니다(구독 API가 503을 반환).
# 새로 생성하려면 backend/ 안에서:
#   python -c "from py_vapid import Vapid; import base64; from cryptography.hazmat.primitives import serialization; v=Vapid(); v.generate_keys(); pub=v.public_key.public_bytes(serialization.Encoding.X962, serialization.PublicFormat.UncompressedPoint); priv=v.private_key.private_numbers().private_value.to_bytes(32,'big'); print('VAPID_PUBLIC_KEY='+base64.urlsafe_b64encode(pub).decode().rstrip('=')); print('VAPID_PRIVATE_KEY='+base64.urlsafe_b64encode(priv).decode().rstrip('='))"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# 푸시 발송 시 VAPID 클레임에 담기는 연락처 (실제 서비스라면 관리자 이메일 권장)
VAPID_CLAIMS_EMAIL=admin@example.com
